# solid-feedback-proxy — environment configuration.
# Copy to `.env` for local dev, or set these as Vercel Project Environment Variables.
# NEVER commit a real .env (it is .gitignored). The GitHub token is a SECRET.

# REQUIRED — the server-side GitHub token used to create issues.
# A FINE-GRAINED Personal Access Token (see the README "GitHub token" section):
#   - Resource owner: jeswr
#   - Repository access: ONLY the repos in FEEDBACK_ALLOWED_REPOS below
#   - Repository permissions: Issues → Read and write  (nothing else)
# Treat like a password. Rotate on suspicion of exposure.
FEEDBACK_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED — the OWNER/REPO values a caller may file against (space/comma separated).
# The token can ONLY ever create issues on repos in this list.
FEEDBACK_ALLOWED_REPOS=jeswr/pod-mail jeswr/pod-drive jeswr/solid-pod-manager jeswr/solid-issues

# REQUIRED — the Solid-OIDC issuers we trust to mint tokens (space/comma separated).
# The suite broker + (for local dev) the loopback dev issuer.
FEEDBACK_TRUSTED_ISSUERS=https://idp.solid-test.jeswr.org http://localhost:8080/realms/solid

# REQUIRED — this proxy's OWN public URL (the expected token `aud`, RFC 9068).
# Must match the audience the suite apps request a token for when calling the proxy.
FEEDBACK_AUDIENCE=https://feedback.solid-test.jeswr.org

# REQUIRED — the browser origins allowed by CORS (space/comma separated).
FEEDBACK_ALLOWED_ORIGINS=https://app.solid-test.jeswr.org https://pod-mail.vercel.app

# OPTIONAL — the exact public endpoint URL the client calls + signs into the DPoP `htu`.
# Defaults to <FEEDBACK_AUDIENCE>/feedback. Used for htu verification, so it is immune to
# the Vercel /feedback -> /api/feedback rewrite. Set only if your public path differs.
# FEEDBACK_PUBLIC_URL=https://feedback.solid-test.jeswr.org/feedback

# OPTIONAL — a stable secret to HMAC the rate-limit keys (WebID/IP) so they are not
# dictionary-reversible. Defaults to a per-instance random value (fine for the in-memory
# limiter). SET A STABLE VALUE if you back the limiter with a shared store (Redis/KV).
# FEEDBACK_HASH_SECRET=replace-with-a-long-random-string

# OPTIONAL — the JWT claim carrying the WebID (default: webid).
# FEEDBACK_WEBID_CLAIM=webid

# OPTIONAL — rate limit: max issues per WebID (and per IP) per window (default: 5).
# FEEDBACK_RATE_LIMIT=5
# OPTIONAL — the rate-limit window in milliseconds (default: 3600000 = 1 hour).
# FEEDBACK_RATE_WINDOW_MS=3600000

# OPTIONAL — max characters accepted in the free-text description (default: 8000).
# FEEDBACK_MAX_DESCRIPTION=8000
