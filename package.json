{
  "name": "solid-feedback-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "Serverless backend that lets non-technical Solid pod users file GitHub issues without a GitHub account: gated on a DPoP-bound Solid-OIDC session, repo-allowlisted, rate-limited, server-side GitHub token. Powers the suite's in-app FeedbackButton submit hook.",
  "type": "module",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeswr/solid-feedback-proxy.git"
  },
  "homepage": "https://github.com/jeswr/solid-feedback-proxy#readme",
  "bugs": {
    "url": "https://github.com/jeswr/solid-feedback-proxy/issues"
  },
  "keywords": [
    "solid",
    "solid-oidc",
    "dpop",
    "rfc9449",
    "github-issues",
    "feedback",
    "vercel",
    "serverless"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint": "biome check src api test",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jose": "6.2.3",
    "oauth4webapi": "3.8.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^24.0.0",
    "@vercel/node": "^5.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  }
}
